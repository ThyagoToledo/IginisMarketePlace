# ── Banco de dados (Neon / Postgres) ─────────────────────────────
# Injetado automaticamente ao conectar o Neon na aba Storage da Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Autenticacao (Auth.js v5 + GitHub OAuth) ─────────────────────
# Segredo para assinar a sessao. Gere com:  openssl rand -base64 33
AUTH_SECRET="cole-um-segredo-aleatorio-aqui"

# Credenciais do GitHub OAuth App (github.com/settings/developers).
# Callback URL do app:  https://SEU-PROJETO.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID="seu_client_id"
AUTH_GITHUB_SECRET="seu_client_secret"

# Em producao na Vercel nao e necessario; util em dev local:
# AUTH_URL="http://localhost:3000"

# ── Admins ───────────────────────────────────────────────────────
# Logins do GitHub que viram admin automaticamente (separados por virgula).
ADMIN_GITHUB_LOGINS="ThyagoToledo,FeronZerbana"

# ── Opcional ─────────────────────────────────────────────────────
# Token do GitHub (escopo public_repo) para checar repos sem bater no rate limit.
GITHUB_TOKEN=""
